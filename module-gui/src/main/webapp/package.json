{
  "name": "svelte-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build-svelte": "rollup -c",
    "dev-svelte": "rollup -c -w",
    "start-svelte": "sirv resources/dist --dev --port 5000",
    "build-riot": "webpack --config webpack.config.cjs",
    "dev-riot": "webpack --config webpack.config.cjs --watch",
    "build": "npm run build-svelte && npm run build-riot"
  },
  "devDependencies": {
    "@babel/core": "^7.4.5",
    "@babel/preset-env": "^7.4.5",
    "@riotjs/compiler": "^4.2.6",
    "@riotjs/webpack-loader": "^4.0.1",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-loader": "^8.0.6",
    "rollup": "^4.57.0",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^5.49.0",
    "webpack": "^5.92.1"
  },
  "dependencies": {
    "riot": "^4.6.6",
    "sirv-cli": "^0.4.4",
    "webpack-cli": "^5.1.4"
  }
}
